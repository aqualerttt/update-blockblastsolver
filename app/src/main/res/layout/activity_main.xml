<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="#1A1A2E">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🧩 Block Blast Solver"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#E0E0FF"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Overlay assistant — no root needed"
        android:textSize="14sp"
        android:textColor="#9090BB"
        android:layout_marginBottom="40dp"/>

    <TextView
        android:id="@+id/statusText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Status: Ready"
        android:textSize="16sp"
        android:textColor="#64FFDA"
        android:layout_marginBottom="32dp"/>

    <Button
        android:id="@+id/btnStart"
        android:layout_width="240dp"
        android:layout_height="56dp"
        android:text="▶  Start Solver"
        android:textSize="16sp"
        android:backgroundTint="#3D5AFE"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btnStop"
        android:layout_width="240dp"
        android:layout_height="56dp"
        android:text="⏹  Stop Solver"
        android:textSize="16sp"
        android:backgroundTint="#424242"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="\n① Tap Start\n② Grant permissions when asked\n③ Switch to Block Blast\n④ Coloured highlights show best moves\n\nP1 = first piece  P2 = second  P3 = third"
        android:textSize="13sp"
        android:textColor="#7070AA"
        android:layout_marginTop="32dp"
        android:lineSpacingMultiplier="1.4"/>

</LinearLayout>
